# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore secret files
**/terraform.tfvars
**/.terraform.tfvars
**/*.auto.tfvars
**/*.auto.tfvars.json

# Ignore SSH keys
**/*.pem
**/*.key
**/id_rsa*
**/id_dsa*

# Ignore backup files
*.bak
*.backup